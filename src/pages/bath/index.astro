---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhoneCTA from '../../components/PhoneCTA.astro';
import { siteConfig } from '../../config';

const { businessName, phone, phoneE164, siteUrl, serviceKeyword, serviceKeywordPlural, city, region, services, cities } = siteConfig;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1),
  "provider": {
    "@type": "LocalBusiness",
    "name": businessName,
    "telephone": phoneE164,
  },
  "areaServed": { "@type": "State", "name": "Kentucky" },
  "description": `Professional ${serviceKeywordPlural} for residential and commercial properties in ${city}.`,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": `${siteUrl}/bath/` },
  ],
};
---

<BaseLayout
  title={`${serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} Services ${city} | ${businessName}`}
  description={`${serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} services in ${city}. We provide ${serviceKeywordPlural} on homes, offices, and commercial buildings across ${region}. Call ${phone} for a free estimate.`}
  canonicalURL={`${siteUrl}/bath/`}
  schema={[breadcrumbSchema, serviceSchema]}
>

<!-- Hero -->
<section class="hero-section">
  <div class="container">
    <h1>{serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} Services in {city}</h1>
    <p class="hero-sub">Residential {serviceKeyword}, commercial {serviceKeyword}, and more. Serving all of {region}.</p>
    <PhoneCTA />
  </div>
</section>

<!-- Photo -->
<div class="container py-6 text-center">
  <img
    src="/photos/hero.jpg"
    alt={`${serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} services in ${city}`}
    class="site-photo mx-auto max-w-2xl"
    loading="eager"
  />
</div>

<!-- Services -->
<div class="content-section">
  <h2 class="text-brand text-xl md:text-2xl font-bold mb-4">Our {serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} Services</h2>

  <p>{businessName} provides professional {serviceKeywordPlural} throughout {city}. We refinish bathtubs, showers, tile surrounds, and countertops in homes and rental properties. Here are the {serviceKeywordPlural} we offer:</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 my-8">
    {services.map((service) => (
      <div class="service-card">
        <img src={service.photo} alt={`${service.title} — ${businessName}`} loading="lazy" />
        <div class="card-body">
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </div>
      </div>
    ))}
  </div>

  <h2 class="text-brand text-xl md:text-2xl font-bold mb-4 mt-8">How Our {serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} Service Works</h2>

  <p>Getting your bathroom refinished by {businessName} is easy. Here's how it works:</p>

  <p><strong>Step 1: Call Us.</strong> Give us a call at {phone} and tell us about the bathtub, shower, or countertop you need refinished. We'll ask about the surface type and condition.</p>

  <p><strong>Step 2: Get Your Free Estimate.</strong> We'll give you a clear, upfront price for your {serviceKeyword}. No hidden fees, no surprises. Most homeowners are surprised at how affordable {serviceKeyword} can be compared to replacement.</p>

  <p><strong>Step 3: We Refinish Your Surface.</strong> Our team arrives on time with all the equipment and supplies needed. We prep, repair, and apply commercial-grade coatings. Most bathtubs are done in 3-5 hours.</p>

  <p><strong>Step 4: Enjoy Your Updated Bathroom.</strong> Your refinished surface will be smooth, glossy, and ready to use in 24-48 hours. Not happy with the results? We'll make it right — that's our 5-year warranty and satisfaction guarantee.</p>

  <h2 class="text-brand text-xl md:text-2xl font-bold mb-4 mt-8">{serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} Service Areas</h2>

  <p>We provide {serviceKeywordPlural} across {city}. We serve:</p>

  <ul>
    {cities.map((c) => (
      <li><a href={`/bath/${c.slug}/`}>{serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} in {c.name}</a></li>
    ))}
  </ul>
</div>

<!-- CTA -->
<section class="bg-gray-50 border-y-2 border-brand">
  <div class="cta-strip container">
    <p class="cta-heading">Ready to Update Your Bathroom?</p>
    <p class="cta-sub">Call now for a free {serviceKeyword} estimate in {city}.</p>
    <PhoneCTA />
  </div>
</section>

<!-- Final CTA -->
<section class="bg-brand-dark text-white">
  <div class="cta-strip container">
    <h2 class="text-white text-xl md:text-2xl font-bold mb-2">Call Now for {serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} in {city}</h2>
    <p class="text-white/90 text-base mb-4">We provide ${serviceKeywordPlural} across {region}.</p>
    <PhoneCTA label="Call Now" />
  </div>
</section>

</BaseLayout>
