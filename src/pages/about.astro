---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneCTA from '../components/PhoneCTA.astro';
import { siteConfig } from '../config';

const { businessName, phone, siteUrl, serviceKeyword, serviceKeywordPlural, city, region, cities } = siteConfig;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "About Us", "item": `${siteUrl}/about/` },
  ],
};

const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": `About ${businessName}`,
  "description": `Learn about ${businessName} — ${city}'s trusted ${serviceKeyword} professionals serving Florence, Covington, Fort Mitchell, and all ${region} cities.`,
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": businessName,
    "telephone": siteConfig.phoneE164,
  },
};
---

<BaseLayout
  title={`About Us | ${businessName} | ${serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} ${city}`}
  description={`${businessName} is a locally owned ${serviceKeyword} company serving ${city}. We refinish bathtubs, showers, and countertops in Florence, Covington, Fort Mitchell, Erlanger, and all across ${region}. Licensed, insured, and backed by a 5-year warranty.`}
  canonicalURL={`${siteUrl}/about/`}
  schema={[breadcrumbSchema, aboutPageSchema]}
>

<!-- Hero -->
<section class="hero-section">
  <div class="container">
    <h1>About {businessName}</h1>
    <p class="hero-sub">Locally owned {serviceKeyword} company serving {city}.</p>
    <PhoneCTA />
  </div>
</section>

<!-- Photo -->
<div class="container py-6 text-center">
  <img
    src="/photos/team.jpg"
    alt={`${businessName} team`}
    class="site-photo mx-auto max-w-2xl"
    loading="eager"
  />
</div>

<!-- About content -->
<div class="content-section">
  <h2 class="text-brand text-xl md:text-2xl font-bold mb-4">Who We Are</h2>

  <p>{businessName} is a locally owned and operated {serviceKeyword} company based in {city}. We restore bathtubs, showers, tile surrounds, and countertops to a like-new finish — at a fraction of replacement cost.</p>

  <p>We started this company because too many homeowners were being told they needed to rip out and replace perfectly good fixtures. Bathroom refinishing saves 75-90% compared to replacement, takes just hours instead of weeks, and delivers results that last 10-15 years. We set out to bring this smart, affordable option to every home in {city}.</p>

  <p>Today, we serve over 15 communities across {city}. Our refinishing team is fully licensed, insured, and background-checked. We use low-VOC, commercial-grade coatings and back every job with a 5-year warranty. We show up on time, do the job right, and stand behind our work with a 100% satisfaction guarantee.</p>

  <img
    src="/photos/residential.jpg"
    alt={`${serviceKeyword.charAt(0).toUpperCase() + serviceKeyword.slice(1)} in ${city}`}
    class="site-photo mx-auto max-w-lg my-6"
    loading="lazy"
  />

  <h2 class="text-brand text-xl md:text-2xl font-bold mb-4 mt-8">What We Do</h2>

  <p>We provide {serviceKeywordPlural} for residential and commercial properties throughout {city}. Our services include:</p>

  <ul>
    {siteConfig.services.map((s) => (
      <li><strong>{s.title}</strong> — {s.description.split('.').slice(0, 2).join('.')}.</li>
    ))}
  </ul>

  <h2 class="text-brand text-xl md:text-2xl font-bold mb-4 mt-8">Why {city} Trusts Us</h2>

  <ul>
    <li>Licensed and insured {serviceKeyword} company</li>
    <li>Background-checked, professional technicians</li>
    <li>On-time arrival — we respect your schedule</li>
    <li>Low-VOC, commercial-grade coatings for lasting durability</li>
    <li>5-year warranty on all refinishing work</li>
    <li>100% satisfaction guarantee on every {serviceKeyword} job</li>
    <li>Locally owned and operated in {city}</li>
    <li>Free estimates — just call {phone}</li>
  </ul>

  <h2 class="text-brand text-xl md:text-2xl font-bold mb-4 mt-8">Where We Serve</h2>

  <p>We provide {serviceKeywordPlural} throughout {city}, including {cities.map((c) => c.name).join(', ')}. If you're in {city} and need bathroom refinishing, call us at {phone}.</p>
</div>

<!-- CTA -->
<section class="bg-gray-50 border-y-2 border-brand">
  <div class="cta-strip container">
    <p class="cta-heading">Ready to Update Your Bathroom?</p>
    <p class="cta-sub">Call now for a free {serviceKeyword} estimate.</p>
    <PhoneCTA />
  </div>
</section>

</BaseLayout>
